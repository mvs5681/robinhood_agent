# Unusual Whales
UW_API_TOKEN=your_token_here
UW_CLIENT_API_ID=100001

# Robinhood (populated by scripts/auth_robinhood.py — do not edit manually)
# RH_ACCESS_TOKEN is NOT required here — a fresh token is always obtained at
# startup by exchanging RH_REFRESH_TOKEN. The new token is saved to TOKEN_FILE
# (/app/logs/rh_tokens.json by default) so restarts reuse the latest credentials.
RH_CLIENT_ID=
RH_REFRESH_TOKEN=
RH_ACCOUNT_NUMBER=your_account_number_here
# TOKEN_FILE=/app/logs/rh_tokens.json  # override token persistence path if needed

# LLM
ANTHROPIC_API_KEY=your_key_here

# Agent behaviour
# TICKERS is optional — if set, these are always scanned regardless of flow activity.
# The scanner also discovers tickers dynamically each hour from get_flow_alerts.
TICKERS=
EXECUTION_MODE=rh_approval   # start here, switch to autonomous after validation
# Quantity: set MAX_TRADE_SPEND for dynamic sizing, or ORDER_QUANTITY for fixed.
# MAX_TRADE_SPEND takes precedence when set.
# qty = floor(MAX_TRADE_SPEND / (option_mid * 100)), capped at MAX_CONTRACTS.
MAX_TRADE_SPEND=500          # max dollars per trade (e.g. 500 → ~1-4 contracts)
MAX_CONTRACTS=20             # hard cap regardless of spend
ORDER_QUANTITY=1             # fallback when MAX_TRADE_SPEND is not set
FLOW_MIN_PREMIUM=100000
DISCOVERY_MIN_PREMIUM=500000  # minimum total premium for a ticker to be discovered
MAX_DISCOVERED_TICKERS=20     # cap on tickers scanned per cycle

# Exit parameters (auto-sell — no approval gate)
STOP_LOSS_PCT=0.35   # close if option premium drops 35% from entry
DTE_FLOOR=7          # close if days-to-expiry reaches this value

# HTTP approval server
HTTP_PORT=8080
PUBLIC_URL=https://your-container-public-address.example.com

# Telegram bot (approve/reject trades directly from Telegram)
# 1. Message @BotFather → /newbot → copy the token
# 2. Start a chat with your bot (send it any message)
# 3. https://api.telegram.org/bot<TOKEN>/getUpdates → copy chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Telemetry
LOG_LEVEL=INFO
TELEMETRY_LOG_FILE=/app/logs/telemetry.jsonl
