# Unusual Whales
UW_API_TOKEN=your_token_here
UW_CLIENT_API_ID=100001

# Robinhood (populated by scripts/auth_robinhood.py — do not edit manually)
RH_CLIENT_ID=
RH_ACCESS_TOKEN=
RH_REFRESH_TOKEN=
RH_ACCOUNT_NUMBER=your_account_number_here

# LLM
ANTHROPIC_API_KEY=your_key_here

# Agent behaviour
# TICKERS is optional — if set, these are always scanned regardless of flow activity.
# The scanner also discovers tickers dynamically each hour from get_flow_alerts.
TICKERS=
EXECUTION_MODE=rh_approval   # start here, switch to autonomous after validation
ORDER_QUANTITY=1
FLOW_MIN_PREMIUM=100000
DISCOVERY_MIN_PREMIUM=500000  # minimum total premium for a ticker to be discovered
MAX_DISCOVERED_TICKERS=20     # cap on tickers scanned per cycle

# HTTP approval server
HTTP_PORT=8080
PUBLIC_URL=https://your-container-public-address.example.com

# Telegram bot (approve/reject trades directly from Telegram)
# 1. Message @BotFather → /newbot → copy the token
# 2. Start a chat with your bot (send it any message)
# 3. https://api.telegram.org/bot<TOKEN>/getUpdates → copy chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Telemetry
LOG_LEVEL=INFO
TELEMETRY_LOG_FILE=/app/logs/telemetry.jsonl
